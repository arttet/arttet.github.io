# Default: auto-detect text, force LF on commit and checkout
* text=auto eol=lf

# Source code
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.svelte    text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.wgsl      text eol=lf

# Content & docs
*.md        text eol=lf
*.mdx       text eol=lf

# Configs & data
*.json      text eol=lf
*.jsonc     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf
*.lock      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# Shell
*.sh        text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.avif      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.mp4       binary
*.webm      binary

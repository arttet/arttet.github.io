{
  "name": "arttet.github.io",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "dev": "vite dev",
    "preview": "vite preview",
    "serve:playwright": "bun run scripts/serve-static.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "VITEST_FAST=true vitest run --maxWorkers=100% --testTimeout=10000 --hookTimeout=10000",
    "test:unit:fast": "VITEST_FAST=true vitest run --maxWorkers=100% --testTimeout=10000 --hookTimeout=10000",
    "test:markdown": "vitest run tests/markdown config/mdsvex",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:coverage:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=target/test-results/vitest.junit.xml --maxWorkers=100% --testTimeout=10000 --hookTimeout=10000",
    "test:lhci": "bun scripts/run-lhci.mjs",
    "test:playwright": "playwright test --config=playwright.config.ts",
    "test:playwright:dev": "playwright test --config=playwright.config.ts",
    "test:playwright:production": "playwright test --config=playwright.ci.config.ts",
    "test:playwright:ui": "playwright test --ui",
    "content:diagnostics": "MARKDOWN_DEBUG=true vite build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "d3-delaunay": "^6.0.4",
    "flexsearch": "^0.8.212",
    "katex": "^0.16.45",
    "lucide-svelte": "^1.0.1",
    "mermaid": "^11.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/enhanced-img": "^0.10.4",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260504.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@webgpu/types": "^0.1.69",
    "cspell": "^10.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.17.1",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "lefthook": "^2.1.6",
    "markdownlint-cli2": "^0.22.1",
    "mdsvex": "^0.12.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "postcss-html": "^1.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte-eslint-parser": "^1.6.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "tmp": "^0.2.4",
    "uuid": "^14.0.0"
  },
  "engines": {
    "bun": ">=1.1",
    "node": ">=24"
  }
}
